# Application
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
TRUST_PROXY=0

# Replace the placeholders with your MongoDB Atlas credentials.
MONGODB_URI=mongodb+srv://naija34:Nyben@72@cluster0.dxbngbx.mongodb.net/

# Generate each secret independently, for example: openssl rand -base64 64
JWT_ACCESS_SECRET=<replace-with-at-least-64-random-characters>
OTP_PEPPER=<replace-with-a-different-64-character-random-secret>
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
REGISTRATION_TOKEN_TTL_MINUTES=30

# OTP controls
OTP_TTL_MINUTES=10
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Comma-separated origins. Native mobile requests normally have no browser origin.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Use "log" locally to print OTP emails to the terminal. Production requires "smtp".
EMAIL_DELIVERY_MODE=log
EMAIL_FROM=34th Street <no-reply@34thstreet.example>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<smtp-username>
SMTP_PASS=<smtp-password>

